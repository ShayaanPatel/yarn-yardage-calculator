---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog — Yarn Yardage Calculator" description="Tips and guides for calculating yarn yardage for your knitting and crochet projects." canonical="https://yarn-yardage-calculator.vercel.app/blog">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">

    <!-- Breadcrumb JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://yarn-yardage-calculator.vercel.app/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://yarn-yardage-calculator.vercel.app/blog" }
      ]
    })} />

    <h1 class="text-3xl font-bold text-[var(--color-text)] mb-8">Yarn Yardage Blog</h1>
    <p class="text-[var(--color-text-secondary)] mb-8">Tips, guides, and resources for estimating yarn yardage and planning your projects.</p>

    <div class="space-y-6">
      <article class="bg-[var(--color-bg-card)] rounded-xl p-6 border border-[var(--color-border)]">
        <time class="text-xs text-[var(--color-text-secondary)]">June 2026</time>
        <h2 class="text-xl font-semibold text-[var(--color-text)] mt-1 mb-2">
          <a href="/blog/how-to-calculate-yarn-yardage" class="hover:text-[var(--color-accent)] transition">How to Calculate Yarn Yardage for Any Project</a>
        </h2>
        <p class="text-sm text-[var(--color-text-secondary)]">A complete guide to estimating how much yarn you need, including formulas, examples, and tips for accurate yardage calculation.</p>
        <a href="/blog/how-to-calculate-yarn-yardage" class="inline-block mt-3 text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] font-medium transition">Read more →</a>
      </article>
    </div>
  </div>
</BaseLayout>
