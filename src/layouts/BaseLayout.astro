---
import '../styles/global.css';
import '../scripts/darkMode';
import '../scripts/calculator';
import SEOHead from '../components/SEOHead.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const pageTitle = title || 'Yarn Yardage Calculator — How Much Yarn Do I Need?';
const pageDescription = description || 'Free yarn yardage calculator for knitting and crochet. Estimate how much yarn you need for scarves, blankets, sweaters, hats, and more. Based on Craft Yarn Council standards.';
const pageCanonical = canonical || 'https://yarn-yardage-calculator.vercel.app';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <SEOHead
      title={pageTitle}
      description={pageDescription}
      canonical={pageCanonical}
    />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Navigation />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- AdSense placeholder (insert your AdSense code here when approved) -->
    <div id="adsense-placeholder" class="no-print" aria-hidden="true"></div>

    <!-- Vercel Analytics -->
    <script>
      // Vercel Analytics loads automatically via @vercel/analytics
      // when deployed via Vercel adapter with webAnalytics enabled
    </script>
  </body>
</html>
